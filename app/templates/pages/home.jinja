{#=====================================================
  Welcome page
=====================================================#}

{% extends 'pages/_base.jinja' %}


{% block content %}

    <h1 class="welcome">To Do List</h1>

        <p>
        {% for task in tasks %}

            <div class="creature">
                <h3>{{ task.name }}</h3>
                <p>priority: <strong>{{ task.priority }}</strong></p>
            </div>

        {% else %}

            <p>No Tasks!</p>

        {% endfor %}
        </p>


    

{% endblock %}

